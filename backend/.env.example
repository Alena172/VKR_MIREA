DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:15432/vkr_db
# Providers: stub | openai_compatible | ollama
AI_PROVIDER=stub
# OpenAI-compatible example: https://api.openai.com/v1
# Ollama from host for Docker backend: http://host.docker.internal:11434/v1
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
# OpenAI-compatible example: gpt-4o-mini
# Ollama example: llama3.1:8b
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
TRANSLATION_STRICT_REMOTE=true
JWT_SECRET=change_me
JWT_ISSUER=vkr
JWT_ACCESS_TTL_MINUTES=1440
# Redis / Celery (for local dev point to localhost; in Docker use redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
